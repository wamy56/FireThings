rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Solo user floor plans: users/{uid}/sites/{siteId}/floor_plans/{filename}
    match /users/{userId}/sites/{siteId}/floor_plans/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Company floor plans: companies/{companyId}/sites/{siteId}/floor_plans/{filename}
    match /companies/{companyId}/sites/{siteId}/floor_plans/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Solo user asset photos: users/{uid}/sites/{siteId}/assets/{assetId}/{filename}
    match /users/{userId}/sites/{siteId}/assets/{assetId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Solo user defect photos: users/{uid}/sites/{siteId}/assets/{assetId}/defects/{defectId}/{filename}
    match /users/{userId}/sites/{siteId}/assets/{assetId}/defects/{defectId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Solo user defect photos (defect_photos path): users/{uid}/sites/{siteId}/assets/{assetId}/defect_photos/{defectId}/{filename}
    match /users/{userId}/sites/{siteId}/assets/{assetId}/defect_photos/{defectId}/{filename} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Company asset photos: companies/{companyId}/sites/{siteId}/assets/{assetId}/{filename}
    match /companies/{companyId}/sites/{siteId}/assets/{assetId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Company defect photos: companies/{companyId}/sites/{siteId}/assets/{assetId}/defects/{defectId}/{filename}
    match /companies/{companyId}/sites/{siteId}/assets/{assetId}/defects/{defectId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Company defect photos (defect_photos path): companies/{companyId}/sites/{siteId}/assets/{assetId}/defect_photos/{defectId}/{filename}
    match /companies/{companyId}/sites/{siteId}/assets/{assetId}/defect_photos/{defectId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Company logos: companies/{companyId}/logo/{filename}
    match /companies/{companyId}/logo/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
