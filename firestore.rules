rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow authenticated users to read app_config
    match /app_config/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User-scoped data — only the owner can read/write
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Company data
    match /companies/{companyId} {

      // Company document: only members can read (join/create via Cloud Functions)
      allow read: if isCompanyMember(companyId);
      allow create: if false;
      allow update: if hasPermission(companyId, 'company_edit');
      allow delete: if hasPermission(companyId, 'company_delete');

      // Members subcollection
      match /members/{memberId} {
        // Members can read all members (team list)
        allow read: if isCompanyMember(companyId);
        // Allow users to check their own membership status
        allow get: if request.auth != null && request.auth.uid == memberId;
        // Only team managers can remove members (via soft-delete)
        allow delete: if hasPermission(companyId, 'team_manage');
        // Joining and founding are now via Cloud Functions only
        allow create: if hasPermission(companyId, 'team_manage');
        // Team managers can update members, but cannot change role or permissions directly
        allow update: if hasPermission(companyId, 'team_manage')
                      && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['role', 'permissions']);
        // Members can update their own fcmToken only
        allow update: if request.auth.uid == memberId
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken']);
        // Members can self-soft-delete (leave company)
        allow update: if request.auth.uid == memberId
                      && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['isActive', 'leftAt'])
                      && request.resource.data.isActive == false;
      }

      // Dispatched jobs
      match /dispatched_jobs/{jobId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasPermission(companyId, 'dispatch_create');
        // Engineers can update status fields on their assigned jobs (no reassignment)
        allow update: if hasPermission(companyId, 'dispatch_edit')
                      || (isCompanyMember(companyId)
                          && resource.data.assignedTo == request.auth.uid
                          && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['status', 'updatedAt', 'completedAt', 'linkedJobsheetId', 'lastUpdatedBy', 'declineReason']));
        allow delete: if hasPermission(companyId, 'dispatch_delete');
      }

      // Shared company sites
      match /sites/{siteId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasPermission(companyId, 'sites_create');
        allow update: if hasPermission(companyId, 'sites_edit');
        allow delete: if hasPermission(companyId, 'sites_delete');

        // Site assets
        match /assets/{assetId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasPermission(companyId, 'assets_create');
          allow update: if hasPermission(companyId, 'assets_edit');
          allow delete: if hasPermission(companyId, 'assets_delete');
        }

        // Floor plans
        match /floor_plans/{planId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasPermission(companyId, 'floor_plans_upload');
          allow update: if hasPermission(companyId, 'floor_plans_edit');
          allow delete: if hasPermission(companyId, 'floor_plans_delete');
        }

        // Asset service history (immutable audit trail)
        match /asset_service_history/{recordId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasPermission(companyId, 'assets_test');
        }

        // Asset defects
        match /defects/{defectId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasPermission(companyId, 'defects_log');
          allow update: if hasPermission(companyId, 'defects_rectify');
          allow delete: if hasPermission(companyId, 'defects_delete');
        }

        // Compliance metadata (immutable audit — admin can update)
        match /compliance_meta/{docId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update: if hasPermission(companyId, 'company_edit');
          allow delete: if false;
        }

        // BS 5839 system config (singleton per site)
        match /bs5839_config/{docId} {
          allow read: if isCompanyMember(companyId);
          allow create, update: if hasPermission(companyId, 'bs5839_config_edit');
          allow delete: if false;
        }

        // Inspection visits (immutable once declared)
        match /inspection_visits/{visitId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasPermission(companyId, 'assets_test');
          allow update: if hasPermission(companyId, 'assets_test')
                        && resource.data.declaration == 'notDeclared';
          allow delete: if false;
        }

        // Variations register (corrections via new records, not edits)
        match /variations/{variationId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update: if hasPermission(companyId, 'bs5839_approve_variations')
                        || (isCompanyMember(companyId)
                            && resource.data.loggedByEngineerId == request.auth.uid);
          allow delete: if false;
        }

        // Cause-and-effect tests (fully immutable audit trail)
        match /cause_effect_tests/{testId} {
          allow read: if isCompanyMember(companyId);
          allow create: if hasPermission(companyId, 'assets_test');
          allow update, delete: if false;
        }

        // Logbook entries
        match /logbook_entries/{entryId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow delete: if hasPermission(companyId, 'company_edit');
          allow update: if false;
        }
      }

      // Asset type configuration
      match /asset_type_config/{typeId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'asset_types_manage');
      }

      // Shared company customers
      match /customers/{customerId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasPermission(companyId, 'customers_create');
        allow update: if hasPermission(companyId, 'customers_edit');
        allow delete: if hasPermission(companyId, 'customers_delete');
      }

      // Completed jobsheets shared with the company
      match /completed_jobsheets/{jobsheetId} {
        allow read: if isCompanyMember(companyId);
        allow create: if isCompanyMember(companyId);
        allow update: if hasPermission(companyId, 'jobsheets_edit');
        allow delete: if hasPermission(companyId, 'jobsheets_delete');
      }

      // Company invoices
      match /invoices/{invoiceId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasPermission(companyId, 'invoices_create');
        allow update: if hasPermission(companyId, 'invoices_edit');
        allow delete: if hasPermission(companyId, 'invoices_delete');
      }

      // Company quotes
      match /quotes/{quoteId} {
        allow read: if isCompanyMember(companyId);
        allow create: if hasPermission(companyId, 'quotes_create');
        allow update, delete: if hasPermission(companyId, 'quotes_edit');
      }

      // Company PDF config
      match /pdf_config/{configId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'pdf_branding');
      }

      // Company branding config
      match /branding/{docId} {
        allow read: if isCompanyMember(companyId);
        allow write: if hasPermission(companyId, 'pdf_branding');
      }

      // Engineer competency (per member)
      match /members/{memberId}/competency/{docId} {
        allow read: if isCompanyMember(companyId);
        allow write: if request.auth.uid == memberId
                     || hasPermission(companyId, 'team_manage');
      }
    }

    // Helper functions

    function isCompanyMember(companyId) {
      return request.auth != null
             && exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid))
             && get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.isActive == true;
    }

    // Check a specific granular permission on the member doc.
    // Admin role always passes as a safety net, even if permissions map is missing.
    function hasPermission(companyId, permission) {
      return isCompanyMember(companyId)
             && (get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role == "admin"
                 || get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.permissions[permission] == true);
    }
  }
}
