rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow authenticated users to read app_config
    match /app_config/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // User-scoped data — only the owner can read/write
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Company data
    match /companies/{companyId} {

      // Company document: readable by any authenticated user (needed for join-by-invite-code query)
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isCompanyAdmin(companyId);

      // Members subcollection
      match /members/{memberId} {
        // Members can read all members (to see team list)
        allow read: if isCompanyMember(companyId);
        // Allow users to check their own membership status (needed for join flow)
        allow get: if request.auth != null && request.auth.uid == memberId;
        // Admins can add/remove members
        allow delete: if isCompanyAdmin(companyId);
        // Admins can create members, OR users can create their own member doc
        allow create: if isCompanyAdmin(companyId)
                      || (request.auth.uid == memberId
                          && request.resource.data.isActive == true
                          && (
                            // Founder: can self-add as admin when company doc doesn't exist yet (same batch)
                            (request.resource.data.role == "admin"
                              && !exists(/databases/$(database)/documents/companies/$(companyId)))
                            // Joiner: can self-add as engineer to an existing company
                            || request.resource.data.role == "engineer"
                          ));
        // Admins can update any member
        allow update: if isCompanyAdmin(companyId);
        // Members can update their own fcmToken
        allow update: if request.auth.uid == memberId
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken']);
      }

      // Dispatched jobs
      match /dispatched_jobs/{jobId} {
        // All company members can read all jobs
        allow read: if isCompanyMember(companyId);
        // Dispatchers and admins can create jobs
        allow create: if isCompanyDispatcherOrAdmin(companyId);
        // Dispatchers/admins can fully update, engineers can update status fields on their assigned jobs
        allow update: if isCompanyDispatcherOrAdmin(companyId)
                      || (isCompanyMember(companyId)
                          && resource.data.assignedTo == request.auth.uid
                          && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['status', 'updatedAt', 'completedAt', 'linkedJobsheetId', 'declineReason', 'assignedTo', 'assignedToName']));
        allow delete: if isCompanyAdmin(companyId);
      }

      // Shared company sites
      match /sites/{siteId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyDispatcherOrAdmin(companyId);

        // Site assets
        match /assets/{assetId} {
          allow read: if isCompanyMember(companyId);
          allow create, update: if isCompanyMember(companyId);
          allow delete: if isCompanyDispatcherOrAdmin(companyId);
        }

        // Floor plans
        match /floor_plans/{planId} {
          allow read: if isCompanyMember(companyId);
          allow create, update: if isCompanyMember(companyId);
          allow delete: if isCompanyDispatcherOrAdmin(companyId);
        }

        // Asset service history (immutable audit trail)
        match /asset_service_history/{recordId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
        }

        // Asset defects
        match /defects/{defectId} {
          allow read: if isCompanyMember(companyId);
          allow create, update: if isCompanyMember(companyId);
          allow delete: if isCompanyDispatcherOrAdmin(companyId);
        }

        // Compliance metadata
        match /compliance_meta/{docId} {
          allow read: if isCompanyMember(companyId);
          allow write: if isCompanyMember(companyId);
        }
      }

      // Asset type configuration
      match /asset_type_config/{typeId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyAdmin(companyId);
      }

      // Shared company customers
      match /customers/{customerId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyDispatcherOrAdmin(companyId);
      }

      // Completed jobsheets shared with the company
      match /completed_jobsheets/{jobsheetId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }

      // Company PDF config
      match /pdf_config/{configId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyAdmin(companyId);
      }
    }

    // Helper functions
    function isCompanyMember(companyId) {
      return request.auth != null
             && exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid))
             && get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.isActive == true;
    }

    function isCompanyAdmin(companyId) {
      return isCompanyMember(companyId)
             && get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role == "admin";
    }

    function isCompanyDispatcherOrAdmin(companyId) {
      return isCompanyMember(companyId)
             && get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role in ["admin", "dispatcher"];
    }
  }
}
