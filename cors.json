[
  {
    "origin": ["*"],
    "method": ["GET", "HEAD", "POST", "PUT", "DELETE", "OPTIONS"],
    "responseHeader": [
      "Content-Type",
      "Content-Length",
      "Content-Range",
      "Content-Encoding",
      "Access-Control-Allow-Origin",
      "Authorization",
      "x-goog-resumable",
      "x-goog-meta-firebasestoragedownloadtokens",
      "x-firebase-storage-version"
    ],
    "maxAgeSeconds": 3600
  }
]
